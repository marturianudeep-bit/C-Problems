#include <stdio.h>

int findEquilibrium(int arr[], int n) {
    int total = 0;
    
    for (int i = 0; i < n; i++) {
        total += arr[i];
    }
    
    int left_sum = 0;
    

    for (int i = 0; i < n; i++) {
        int right_sum = total - left_sum - arr[i];
        
        if (left_sum == right_sum) {
            return i; 
        }
        
        left_sum += arr[i];
    }
    
    return -1;
}

int main() {
    int n;
    scanf("%d", &n);
    
    int arr[n];
    
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    
    int result = findEquilibrium(arr, n);
    
    printf("%d\n", result);
    
    return 0;
}
