#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int price;
    int min = -1; 

    for (int i = 0; i < n; i++) {
        scanf("%d", &price);

        if (price > 0) {
            if (min == -1 || price < min) {
                min = price;
            }
        }
    }

    if (min == -1) {
        printf("No positive");
    } else {
        printf("%d", min);
    }

    return 0;
}
