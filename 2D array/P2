#include <stdio.h>
#include <limits.h>

int main() {
    int R, C;
    scanf("%d %d", &R, &C);

    int arr[R][C];


    for(int i = 0; i < R; i++) {
        for(int j = 0; j < C; j++) {
            scanf("%d", &arr[i][j]);
        }
    }

    int maxProduct = INT_MIN;

  
    for(int i = 0; i < R; i++) {

        int max1 = INT_MIN, min1 = INT_MAX;

    
        for(int j = 0; j < C; j++) {
            if(arr[i][j] > max1)
                max1 = arr[i][j];
            if(arr[i][j] < min1)
                min1 = arr[i][j];
        }

        for(int k = i + 1; k < R; k++) {

            int max2 = INT_MIN, min2 = INT_MAX;

        
            for(int j = 0; j < C; j++) {
                if(arr[k][j] > max2)
                    max2 = arr[k][j];
                if(arr[k][j] < min2)
                    min2 = arr[k][j];
            }

  
            int prod1 = max1 * max2;
            int prod2 = min1 * min2;

            if(prod1 > maxProduct)
                maxProduct = prod1;

            if(prod2 > maxProduct)
                maxProduct = prod2;
        }
    }

    printf("%d\n", maxProduct);

    return 0;
}
