#include <stdio.h>

int main() {
    int R, C;
    scanf("%d %d", &R, &C);

    int matrix[R][C];
    for(int i = 0; i < R; i++) {
        for(int j = 0; j < C; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int count = 0;
    for(int i = 0; i < R; i++) {
        for(int j = 0; j < C; j++) {

            int isRowMin = 1;
            int isColMax = 1;
            for(int k = 0; k < C; k++) {
                if(matrix[i][k] < matrix[i][j]) {
                    isRowMin = 0;
                    break;
                }
            }
            for(int k = 0; k < R; k++) {
                if(matrix[k][j] > matrix[i][j]) {
                    isColMax = 0;
                    break;
                }
            }

            if(isRowMin && isColMax) {
                count++;
            }
        }
    }

    printf("%d\n", count);

    return 0;
}
