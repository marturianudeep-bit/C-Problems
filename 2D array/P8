#include <stdio.h>

int main() {
    int R, C;
    scanf("%d %d", &R, &C);
    
    int matrix[R][C];
    for(int i = 0; i < R; i++) {
        for(int j = 0; j < C; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }
    
    int maxSum = -1000000; 
    for(int i = 0; i < R - 1; i++) {
        for(int j = 0; j < C - 1; j++) {
            int currentSum = matrix[i][j] 
                           + matrix[i][j+1] 
                           + matrix[i+1][j] 
                           + matrix[i+1][j+1];
            
            if(currentSum > maxSum) {
                maxSum = currentSum;
            }
        }
    }
    printf("%d\n", maxSum);
    
    return 0;
}
