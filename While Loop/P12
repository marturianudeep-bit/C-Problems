#include<stdio.h>
int main(){
    int N;
    scanf("%d",&N);

    int usage[N];
    int i = 0;

    while(i < N){
        scanf("%d",&usage[i]);
        i++;
    }
    int maxUsage = usage[0];
    int surgeHours = 0;

    i = 0;

    while(i < N){
        if(usage[i] > maxUsage){
            maxUsage = usage[i];
        }
        if(usage[i] > 5){
            surgeHours++;
        }
        i++;
    }
    printf("Max Usage: %d\n",maxUsage);
    printf("Surge HOurs: %d\n",surgeHours);

    return 0;
}
