#include<stdio.h>
int main(){
    int dataPack,N;
    scanf("%d",&dataPack);
    scanf("%d",&N);

    int usage[N];
    for(int i = 0; i < N; i++){
        scanf("%d",&usage[i]);
    }
    int  i = 0;
    int exhaustedDay = -1;
    int overused = 0;

    while(i < N){
        dataPack -= usage[i];
        if(dataPack <= 0){
            exhaustedDay = i + 1;
            if(dataPack < 0)
            overused = -dataPack;
            break;
        }
        i++;
    }
    if(exhaustedDay == -1){
        printf("Exhausted Day: Not Exhausted\n");
        printf("Overused Data: 0\n");
    }else{
        printf("Exhausted Day: %d\n",exhaustedDay);
        printf("Overused Data: %d\n",overused);
    }
    return 0;
}
