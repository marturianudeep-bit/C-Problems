#include<stdio.h>
int main(){
    int N;
    scanf("%d",&N);

    int hours[N];
    for(int i = 0; i < N; i++){
        scanf("%d",&hours[i]);
    }
    int i = 0;
    int total = 0;
    int burnoutDays = 0;

    while(i < N){
        total += hours[i];

        if(hours[i] > 4){
            burnoutDays++;
        }
        i++;
    }
    printf("Total Overtime: %d\n",total);
    printf("Burnout Days: %d\n",burnoutDays);

    return 0;
    
}
