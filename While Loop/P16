#include<stdio.h>
int main(){
    int maxWeight;
    int N;
    int weight;
    int  i = 0;
    int totalWeight = 0 ;
    int peopleEntered = 0;
    int overload = 0;

    scanf("%d",&maxWeight);
    scanf("%d",&N);

    while(i < N){
        scanf("%d",&weight);

        if(totalWeight + weight > maxWeight){
            overload = 1;
            break;
        }
        totalWeight += weight;
        peopleEntered++;
        i++;
    }
    printf("People Entered: %d\n",peopleEntered);
    printf("Overload Status: %s\n",overload ? "YEs" : "NO");

    return 0;

}
