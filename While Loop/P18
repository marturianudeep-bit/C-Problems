#include<stdio.h>
int main(){
    int capacity,N;
    int load;
    int i = 0;
    int safeHours = 0;
    int failures = 0;

    scanf("%d",&capacity);
    scanf("%d",&N);

    while(i < N){
        scanf("%d",&load);

        if(load > capacity){
            failures++;
        }else{
            safeHours++;
        }
        i++;
    }
    printf("Safe HOurs: %d\n",safeHours);
    printf("Failure Count: %d\n",failures);

    return 0;
}
