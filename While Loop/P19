#include<stdio.h>
int main(){
    int maxCapacity,N;
    int patients;
    int i = 0;
    int treated = 0;
    int rejected = 0;

    scanf("%d",&maxCapacity);
    scanf("%d",&N);

    while(i < N){
        scanf("%d",&patients);

        if(treated + patients <= maxCapacity){
            treated += patients;
        }else{
            rejected += (treated + patients - maxCapacity);
            treated = maxCapacity;
        }
        i++;
    }
    printf("Treated Patients: %d\n",treated);
    printf("Rejected Patients: %d\n",rejected);

    return 0;
}
