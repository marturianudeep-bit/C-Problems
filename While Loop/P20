#include<stdio.h>
int main(){
    int N;
    scanf("%d",&N);

    int arr[N];
    int i = 0;

    while(i < N){
        scanf("%d",&arr[i]);
        i++;
    }
    int totalDrops = 0;
    int consecutive = 0;
    int crashDay = -1;

    i = 1;
    while(i < N){
        if(arr[i] < arr[i - 1]){
            totalDrops++;
            consecutive++;

            if(consecutive == 3 && crashDay == -1){
                crashDay = i + 1;
            }
        }else{
            consecutive = 0;
        }
        i++;
    }
    if(crashDay == -1)
    printf("Crash Day: Not Detected\n");
    else
    printf("Crash Day: %d\n",crashDay);

    printf("Total Drops: %d\n",totalDrops);

    return 0;
}
