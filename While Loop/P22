#include<stdio.h>
int main(){
    int n,i = 0,attempt;
    int failed = 0,consecutiveFail = 0;
    int lockAttempt = -1;

    scanf("%d",&n);

    while("%d",&n){
        scanf("%d",&attempt);

        if(attempt == 0){
            failed++;
            consecutiveFail++;

            if(consecutiveFail == 3 && lockAttempt == -1)
            lockAttempt = i + 1;
        }
        else{
            consecutiveFail = 0;
        }
        i++;
    }
    if(lockAttempt == -1)
    printf("Lock Triggered At Attempt: Not Locked\n");
    else
    printf("Lock Triggered At Attempt: %d\n",lockAttempt);

    return 0;
}
