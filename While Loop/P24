#include<stdio.h>
int main(){
    int fuel,n,i = 0,burn;
    int emergencyStage = -1;
    int wasted = 0;

    scanf("%d",&fuel);
    scanf("%d",&n);

    while(i < n){
        scanf("%d",&burn);
        fuel -= burn;

        if(fuel < 0 && emergencyStage == -1){
            emergencyStage = i + 1;
            wasted =  -fuel;
        }
        i++;
    }
    if(emergencyStage == -1)
      printf("Emergency Stage: Not Occured\nFuel Wasted");
      else{
        printf("Emergency Stage: %d\n",emergencyStage);
        printf("Fuel Wasted: %d",wasted);
      }
      return 0;
}
